# Example environment variables for OpenCron
# Create a real `.env` (do NOT commit it) or set these in your host (Render secrets, etc.)

# GitHub personal access token with `repo` scope (or a token with repo:contents permissions)
# Example: GH_PAT=ghp_xxx
GH_PAT=

# Repository to push logs to in owner/repo format (e.g. "Enzo-21/opencron")
GH_REPO="Enzo-21/opencron"

# Branch to push to (default: main)
GH_BRANCH=main

# Interval (ms) between syncs from the server to GitHub. Default is 6 hours.
# For example, 3600000 = 1 hour, 21600000 = 6 hours
GH_SYNC_INTERVAL_MS=21600000

# If you want the old GH Action to run too, keep APP_URL or LOGS_ENDPOINT secrets populated
# APP_URL=https://opencron.example.com
# LOGS_ENDPOINT=${APP_URL}/api/cron/export-logs
